{
  "imports": {
    "@disjukr/bdl/ir": "jsr:@disjukr/bdl@0.8.3/ir",
    "@disjukr/bdl/ir/builder": "jsr:@disjukr/bdl@0.8.3/ir/builder",
    "@disjukr/bdl/io/config": "jsr:@disjukr/bdl@0.8.3/io/config"
  },
  "tasks": {
    "codegen:typescript": "deno run -A ./scripts/codegen/typescript/main.ts --standard wire --schema ./protocol/schemas/wire --out ./web/src/protocol/generated/wire.ts --cbor-import ../cbor.ts && deno run -A ./scripts/codegen/typescript/main.ts --standard rpc --schema ./protocol/schemas/rpc --out ./web/src/protocol/generated/rpc.ts --rpc-client-out ./web/src/protocol/generated/client.ts --cbor-import ../cbor.ts --generated-import ./rpc.ts --rpc-runtime-import ../client.ts",
    "macos:dev:desktop": "./scripts/macos/dev-desktop.sh",
    "macos:kill:desktop": "./scripts/macos/kill-desktop.sh",
    "macos:package:desktop": "./scripts/macos/package-desktop-dmg.sh",
    "macos:pair:dev": "./scripts/macos/pair-dev.sh",
    "windows:dev:desktop": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/dev-desktop.ps1",
    "windows:kill:desktop": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/kill-desktop.ps1",
    "windows:package:desktop": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/package-desktop-msi.ps1",
    "windows:package:desktop:msix": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/package-desktop-msix.ps1",
    "windows:pair:dev": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/pair-dev.ps1",
    "windows:trust:desktop:dev-cert": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows/trust-desktop-dev-certificate.ps1"
  }
}
